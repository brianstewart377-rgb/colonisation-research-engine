{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cre.local/schemas/unknown.schema.json",
  "title": "CRE Unknown",
  "description": "Documentation-first draft schema for unresolved knowledge gaps that remain visible to planners and release manifests.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "unknown_id",
    "category",
    "status",
    "summary",
    "unknown_statement",
    "source_refs",
    "planner_implications"
  ],
  "properties": {
    "unknown_id": {
      "type": "string",
      "pattern": "^U-\\d{4}$"
    },
    "category": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Open",
        "Partially Bounded",
        "Under Test",
        "Governance Decision Needed",
        "Resolved",
        "Superseded"
      ]
    },
    "summary": {
      "type": "string"
    },
    "unknown_statement": {
      "type": "string"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "related_mechanics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_contradictions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_live_verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_governance_decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "planner_implications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "publication_effect": {
      "type": "string",
      "enum": [
        "confidence_label_only",
        "downgrade_release",
        "block_release_item",
        "requires_live_test",
        "requires_governance_decision"
      ]
    },
    "provenance_links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provenanceLink"
      }
    },
    "confidence": {
      "$ref": "#/$defs/confidenceBand"
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "confidenceBand": {
      "type": "string",
      "enum": [
        "High that the gap exists",
        "Medium that the gap exists",
        "Low that the gap exists",
        "Unknown"
      ]
    },
    "provenanceLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_entity",
        "relationship"
      ],
      "properties": {
        "source_entity": {
          "type": "string"
        },
        "relationship": {
          "type": "string",
          "enum": [
            "derived_from",
            "bounded_by",
            "tests",
            "blocks",
            "informs",
            "resolved_by"
          ]
        },
        "basis_note": {
          "type": "string"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "review_status": {
          "type": "string",
          "enum": [
            "unreviewed",
            "analyst_reviewed",
            "release_visible",
            "resolved",
            "superseded"
          ]
        },
        "reviewer": {
          "type": "string"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
