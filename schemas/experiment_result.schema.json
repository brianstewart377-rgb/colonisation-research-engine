{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cre.local/schemas/experiment_result.schema.json",
  "title": "CRE Experiment Result",
  "description": "Documentation-first draft schema for completed live-verification or experiment outcomes linked to protocols, observations, claims, and planner implications.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experiment_result_id",
    "status",
    "title",
    "objective",
    "method_summary",
    "result_summary",
    "confidence",
    "source_refs"
  ],
  "properties": {
    "experiment_result_id": {
      "type": "string"
    },
    "linked_verification_item": {
      "type": "string"
    },
    "linked_protocol": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Planned",
        "In Progress",
        "Completed",
        "Inconclusive",
        "Failed Methodologically",
        "Superseded"
      ]
    },
    "title": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "method_summary": {
      "type": "string"
    },
    "hold_constant": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_variables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recorded_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "result_summary": {
      "type": "string"
    },
    "outcome_type": {
      "type": "string",
      "enum": [
        "supports",
        "weakens",
        "refutes",
        "bounds",
        "inconclusive"
      ]
    },
    "observation_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_mechanics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_contradictions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "planner_implications": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publication_recommendation": {
      "type": "string",
      "enum": [
        "no_change",
        "raise_confidence",
        "downgrade_confidence",
        "publish_claim",
        "update_projection",
        "open_new_unknown"
      ]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "provenance_links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provenanceLink"
      }
    },
    "confidence": {
      "$ref": "#/$defs/confidenceBand"
    },
    "patch_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "patch_family": {
          "type": "string"
        },
        "patch_label": {
          "type": "string"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "confidenceBand": {
      "type": "string",
      "enum": [
        "High",
        "Medium",
        "Low",
        "Unknown"
      ]
    },
    "provenanceLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_entity",
        "relationship"
      ],
      "properties": {
        "source_entity": {
          "type": "string"
        },
        "relationship": {
          "type": "string",
          "enum": [
            "derived_from",
            "recorded_as",
            "supports",
            "weakens",
            "refutes",
            "bounds",
            "creates"
          ]
        },
        "basis_note": {
          "type": "string"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "review_status": {
          "type": "string",
          "enum": [
            "unreviewed",
            "analyst_reviewed",
            "knowledge_updated",
            "disputed",
            "superseded"
          ]
        },
        "reviewer": {
          "type": "string"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
