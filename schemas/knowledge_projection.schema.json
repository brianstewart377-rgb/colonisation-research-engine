{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cre.local/schemas/knowledge_projection.schema.json",
  "title": "CRE Knowledge Projection",
  "description": "Documentation-first draft schema for planner-safe projections derived from mechanics, current observations, claims, and publication rules rather than raw evidence alone.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projection_id",
    "projection_type",
    "status",
    "projection_statement",
    "planner_safe_confidence",
    "knowledge_version",
    "source_basis"
  ],
  "properties": {
    "projection_id": {
      "type": "string"
    },
    "projection_type": {
      "type": "string",
      "description": "Examples: body_feasibility_projection, economy_projection, recommendation_constraint, strategy_projection, service_projection."
    },
    "status": {
      "type": "string",
      "enum": [
        "Published",
        "Published with Caveat",
        "Experimental",
        "Withheld",
        "Superseded"
      ]
    },
    "projection_statement": {
      "type": "string"
    },
    "projection_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "body_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "facility_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "objective_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "role_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "knowledge_version": {
      "type": "string"
    },
    "patch_partition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "patch_family": {
          "type": "string"
        },
        "patch_label": {
          "type": "string"
        },
        "knowledge_window_start": {
          "type": "string",
          "format": "date-time"
        },
        "knowledge_window_end": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "source_basis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "mechanic_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "observation_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contradiction_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unknown_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "governance_rule_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "planner_safe_confidence": {
      "type": "string",
      "enum": [
        "Confirmed",
        "Likely",
        "Experimental",
        "Unknown"
      ]
    },
    "publication_decision": {
      "type": "string",
      "enum": [
        "publish",
        "publish_with_caveat",
        "withhold",
        "downgrade",
        "needs_review"
      ]
    },
    "planner_implications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "what_would_change": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unsupported_requests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance_links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provenanceLink"
      }
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "provenanceLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_entity",
        "relationship"
      ],
      "properties": {
        "source_entity": {
          "type": "string"
        },
        "relationship": {
          "type": "string",
          "enum": [
            "derived_from",
            "supported_by",
            "qualified_by",
            "limited_by",
            "blocked_by",
            "published_from",
            "withheld_due_to"
          ]
        },
        "basis_note": {
          "type": "string"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "review_status": {
          "type": "string",
          "enum": [
            "unreviewed",
            "analyst_reviewed",
            "planner_safe",
            "withheld",
            "superseded"
          ]
        },
        "reviewer": {
          "type": "string"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
