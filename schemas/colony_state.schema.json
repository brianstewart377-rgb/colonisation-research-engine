{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cre.local/schemas/colony_state.schema.json",
  "title": "CRE Colony State",
  "description": "Documentation-first draft schema for representing current colony state, evidence linkage, and planner-safe context.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "knowledge_version",
    "state_timestamp",
    "system",
    "bodies",
    "facilities"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this schema contract."
    },
    "knowledge_version": {
      "type": "string",
      "description": "Knowledge release version used when producing this state object."
    },
    "state_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this colony-state view was assembled."
    },
    "patch_context": {
      "$ref": "#/$defs/patchContext"
    },
    "system": {
      "$ref": "#/$defs/system"
    },
    "bodies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/body"
      }
    },
    "facilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/facility"
      }
    },
    "market_links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/marketLink"
      },
      "description": "Observed or inferred market-link relationships relevant to the current state."
    },
    "economy_snapshots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/economySnapshot"
      }
    },
    "services": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/servicePresence"
      }
    },
    "commodity_observations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/commodityObservation"
      }
    },
    "planner_constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plannerConstraint"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/refString"
      },
      "description": "Evidence IDs contributing directly to this state object."
    },
    "claim_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/refString"
      },
      "description": "Claims currently informing this state object."
    },
    "unknown_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/refString"
      },
      "description": "Unknowns that materially limit interpretation of this state."
    },
    "review": {
      "$ref": "#/$defs/review"
    }
  },
  "$defs": {
    "refString": {
      "type": "string",
      "minLength": 1
    },
    "patchContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "patch_family": {
          "type": "string"
        },
        "patch_label": {
          "type": "string"
        },
        "patch_window_start": {
          "type": "string",
          "format": "date-time"
        },
        "patch_window_end": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_name"
      ],
      "properties": {
        "system_name": {
          "type": "string"
        },
        "architect_name": {
          "type": "string"
        },
        "architect_confidence": {
          "$ref": "#/$defs/confidenceBand"
        },
        "population": {
          "type": "number"
        },
        "security": {
          "type": "number"
        },
        "wealth": {
          "type": "number"
        },
        "development": {
          "type": "number"
        },
        "technology": {
          "type": "number"
        },
        "living_standards": {
          "type": "number"
        },
        "state_confidence": {
          "$ref": "#/$defs/confidenceBand"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        }
      }
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "body_ref",
        "body_name",
        "body_class"
      ],
      "properties": {
        "body_ref": {
          "type": "string"
        },
        "body_name": {
          "type": "string"
        },
        "body_class": {
          "type": "string"
        },
        "build_surface_allowed": {
          "type": "boolean"
        },
        "orbital_only": {
          "type": "boolean"
        },
        "slot_summary": {
          "$ref": "#/$defs/slotSummary",
          "description": "Body-level placement capacity summary. Slot counts represent capacity or predicted occupancy context, not built facility identity."
        },
        "base_economy_hypotheses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/economyHypothesis"
          }
        },
        "body_modifiers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "role_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidenceBand"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        }
      }
    },
    "slotSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "orbital_slots": {
          "type": "integer",
          "minimum": 0
        },
        "surface_slots": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "economyHypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "economy_name"
      ],
      "properties": {
        "economy_name": {
          "type": "string"
        },
        "hypothesis_type": {
          "type": "string",
          "enum": [
            "base",
            "modifier",
            "inherited",
            "observed",
            "predicted"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/confidenceBand"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        }
      }
    },
    "facility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "facility_ref",
        "facility_name",
        "facility_type"
      ],
      "properties": {
        "facility_ref": {
          "type": "string"
        },
        "facility_name": {
          "type": "string"
        },
        "facility_type": {
          "type": "string",
          "description": "Facility class or family label for the facility instance."
        },
        "station_type": {
          "type": "string",
          "description": "Optional station-type taxonomy such as Orbis or Dodec. This is not equivalent to final inherited economy state."
        },
        "body_ref": {
          "type": "string"
        },
        "location_resolution": {
          "type": "string",
          "enum": [
            "resolved",
            "system_only",
            "uncertain"
          ]
        },
        "state": {
          "type": "string",
          "enum": [
            "preview",
            "planned",
            "under_construction",
            "completed",
            "unknown"
          ]
        },
        "role_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        },
        "service_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        },
        "economy_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          },
          "description": "Observed, preview, or predicted economy-state references associated with the facility. These are not planning-role labels."
        },
        "confidence": {
          "$ref": "#/$defs/confidenceBand"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        }
      }
    },
    "marketLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_facility_ref",
        "link_economy",
        "link_strength"
      ],
      "properties": {
        "source_facility_ref": {
          "type": "string"
        },
        "target_facility_ref": {
          "type": "string"
        },
        "link_economy": {
          "type": "string",
          "description": "The economy dimension or economy-state label associated with the market-link interpretation, not an economy-role label."
        },
        "link_strength": {
          "type": "string",
          "enum": [
            "strong",
            "weak",
            "unknown"
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "aggregation_status": {
          "type": "string",
          "enum": [
            "direct",
            "possibly_aggregated",
            "unknown"
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        }
      }
    },
    "economySnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_ref",
        "subject_type",
        "economy_name"
      ],
      "properties": {
        "subject_ref": {
          "type": "string"
        },
        "subject_type": {
          "type": "string",
          "enum": [
            "system",
            "body",
            "facility"
          ]
        },
        "economy_name": {
          "type": "string",
          "description": "Economy state label recorded for the subject. This is not the same thing as a contextual role such as Industrial Anchor."
        },
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "value_percent": {
          "type": "number",
          "minimum": 0
        },
        "snapshot_kind": {
          "type": "string",
          "enum": [
            "observed",
            "predicted",
            "preview"
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        }
      }
    },
    "servicePresence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "facility_ref",
        "service_name"
      ],
      "properties": {
        "facility_ref": {
          "type": "string"
        },
        "service_name": {
          "type": "string"
        },
        "service_state": {
          "type": "string",
          "enum": [
            "present",
            "absent",
            "unknown"
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        }
      }
    },
    "commodityObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "facility_ref",
        "commodity_name",
        "observation_kind"
      ],
      "properties": {
        "facility_ref": {
          "type": "string"
        },
        "commodity_name": {
          "type": "string"
        },
        "observation_kind": {
          "type": "string",
          "enum": [
            "visible_for_sale",
            "visible_for_purchase",
            "missing",
            "predicted",
            "unknown"
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        }
      }
    },
    "plannerConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constraint_type",
        "statement"
      ],
      "properties": {
        "constraint_type": {
          "type": "string"
        },
        "statement": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "hard_block",
            "strong_warning",
            "soft_warning"
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "review_status": {
          "type": "string",
          "enum": [
            "unreviewed",
            "analyst_reviewed",
            "corroborated",
            "disputed",
            "superseded"
          ]
        },
        "reviewer": {
          "type": "string"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "review_notes": {
          "type": "string"
        }
      }
    },
    "confidenceBand": {
      "type": "string",
      "enum": [
        "Confirmed",
        "Likely",
        "Experimental",
        "Unknown"
      ]
    }
  }
}
